{
  "name": "db-player",
  "displayName": "DB Player",
  "description": "PostgreSQL, MySQL, and SQL Server in one webview—browse schemas, run queries, and edit with less UI fragmentation than typical multi-panel database extensions.",
  "version": "0.1.2",
  "publisher": "lilr",
  "keywords": [
    "dbplayer",
    "db player",
    "database",
    "postgres",
    "postgresql",
    "mysql",
    "mariadb",
    "sqlserver",
    "mssql",
    "sql",
    "webview"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JIM-GLITCH/solid-bun-postgresql"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["*"],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "db-player.helloWorld",
        "title": "Open DB Player",
        "category": "DB Player"
      }
    ],
    "uriHandler": {},
    "configuration": {
      "title": "DB Player",
      "properties": {
        "dbPlayer.subscriptionApiUrl": {
          "type": "string",
          "default": "https://api.dbplayer.top",
          "description": "订阅服务 API 根地址（用于 /api/verify-license 等，勿以 / 结尾）"
        },
        "dbPlayer.subscriptionFrontendUrl": {
          "type": "string",
          "default": "https://dbplayer.top",
          "description": "订阅/登录 Web 页面根地址（支付与 vscode:// 回跳说明中的站点）"
        }
      }
    }
  }
}
