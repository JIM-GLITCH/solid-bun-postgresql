# 复制为 .env 并填写真实值
# cp .env.example .env

# 数据库
DATABASE_URL=postgresql://user:pass@host:5432/subscription

# JWT（自己生成：openssl rand -hex 32）
JWT_SECRET=your-jwt-secret-here

# GitHub OAuth App
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Personal Access Token，用于自动更新 OAuth callback URL（需要 write:applications 权限）
GITHUB_PAT=ghp_xxxx

# 前端地址（订阅页面）
FRONTEND_URL=https://your-frontend.oss-cn-hangzhou.aliyuncs.com

# 后端地址（FC HTTP 触发器地址，部署后填写）
API_BASE_URL=https://your-fc-endpoint.cn-hangzhou.fcapp.run

# 支付宝：由 ALIPAY_SANDBOX 决定读哪一套变量（不要混用）
ALIPAY_SANDBOX=false
# 正式环境（ALIPAY_SANDBOX 不为 true/1/yes 时使用）
ALIPAY_APP_ID=your-alipay-app-id
# 应用私钥 RSA2（PKCS1/PKCS8 PEM 均可），必须与开放平台里「上传的应用公钥」成对；勿填成支付宝公钥
# 多行 PEM 请用双引号包裹整块（从 -----BEGIN 到 -----END），或写成一行并用 \n 表示换行；勿裸写多行否则 deploy 曾会只读到第一行
ALIPAY_PRIVATE_KEY=your-alipay-private-key
# 支付宝公钥（开发设置页「支付宝公钥」），用于验签异步通知；勿填成你自己生成的应用公钥
ALIPAY_PUBLIC_KEY=your-alipay-public-key
# 沙箱环境（ALIPAY_SANDBOX=true 时使用，与上面三套独立）
ALIPAY_SANDBOX_APP_ID=your-sandbox-app-id
ALIPAY_SANDBOX_PRIVATE_KEY=your-sandbox-app-private-key
ALIPAY_SANDBOX_PUBLIC_KEY=your-sandbox-alipay-public-key
# 沙箱若电脑网站支付异常，可试 ALIPAY_USE_WAP_PAY=true（手机网站支付 QUICK_WAP_WAY）
ALIPAY_USE_WAP_PAY=false
# 可选：开放平台开启「接口内容加密（AES）」时必填，否则网关报 missing-encrypt-key
# 沙箱：ALIPAY_SANDBOX_AES_KEY（或 ALIPAY_SANDBOX_ENCRYPT_KEY）；正式：ALIPAY_AES_KEY（或 ALIPAY_ENCRYPT_KEY）
# 值为该页展示的 Base64 AES 密钥；填好后需写入 FC 环境并重新部署
# ALIPAY_AES_KEY=
# ALIPAY_SANDBOX_AES_KEY=

# 微信支付
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_PUBLIC_KEY=your-wechat-public-key
WECHAT_PRIVATE_KEY=your-wechat-private-key
WECHAT_SERIAL_NO=your-wechat-serial-no

# ACR 镜像仓库命名空间
ACR_NAMESPACE=your-namespace
