{
  "name": "solid-project",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "dev": "bun standalone/dev.ts",
    "deploy": "bun standalone/deploy.ts",
    "build-win": "bun standalone/build-win.ts",
    "build-linux": "bun standalone/build-linux.ts",
    "standalone:dev": "bun run standalone/dev.ts",
    "standalone:build:linux": "bun run standalone/build-linux.ts",
    "standalone:build:win": "bun run standalone/build-win.ts",
    "standalone:deploy": "bun run standalone/deploy.ts",
    "vscode-extension:build": "bun run vscode-extension/build.ts",
    "vscode-extension:publish": "bun run vscode-extension/build.ts; cd vscode-extension; vsce publish",
    "electrobun:start": "bun run build:electrobun ; bunx electrobun dev",
    "build:electrobun": "bun run build:electrobun:frontend && bun install && bunx electrobun build",
    "build:electrobun:frontend": "bun run electrobun-app/build.ts",
    "electrobun:package:canary": "bun run build:electrobun:frontend && bunx electrobun build --env=canary",
    "electrobun:package:stable": "bun run build:electrobun:frontend && bunx electrobun build --env=stable",
    "electrobun:portable": "bun run electrobun-app/package-portable.ts"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
