{
  "name": "solid-project",
  "version": "0.0.0",
  "description": "",
  "scripts": {
    "deploy": "bun standalone/deploy.ts",
    "dev": "concurrently -n api,vite \"tsx standalone/server-node.ts\" \"vp dev\"",
    "dev:standalone": "vp dev -c standalone/vite.config.standalone.ts",
    "build:linux": "bun run standalone/build-linux.ts",
    "build:win": "bun run standalone/build-win.ts",
    "build:sea": "bun standalone/build-sea.ts",
    "build:sea:deploy": "bun standalone/build-sea-linux.ts",
    "build-extension": "bun run vscode-extension/build.ts",
    "publish-extension": "bun run build-extension && cd vscode-extension && vsce publish --allow-star-activation  && ovsx publish --allow-star-activation ",
    "electrobun:start": "bun run build:electrobun ; bunx electrobun dev",
    "build:electrobun": "bun run build:electrobun:frontend  && bunx electrobun build",
    "build:electrobun:frontend": "bun run electrobun-app/build.ts",
    "electrobun:package:canary": "bun run build:electrobun:frontend && bunx electrobun build --env=canary",
    "electrobun:package:stable": "bun run build:electrobun:frontend && bunx electrobun build --env=stable",
    "electrobun:portable": "bun run electrobun-app/package-portable.ts",
    "subscription:dev": "bun run subscription-dev.ts",
    "subscription:dev:all": "cd subscription/backend && bun run dev-with-portal.ts",
    "subscription:dev:watch": "cd subscription/backend && bun run dev:all"
  },
  "license": "MIT",
  "pkg": {
    "assets": [
      "standalone/out/**"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@dschz/bun-plugin-solid": "^1.0.4",
    "@fast-check/vitest": "^0.3.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/bun": "^1.3.4",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/node-forge": "^1.3.14",
    "@types/pg-cursor": "^2.7.2",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "babel-preset-solid": "^1.9.10",
    "baseline-browser-mapping": "^2.9.14",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.1",
    "fast-check": "^4.6.0",
    "jsdom": "^25.0.1",
    "pkg": "^5.8.1",
    "solid-devtools": "^0.34.3",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vite-plugin-solid": "2.11.9",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@corvu/resizable": "^0.2.5",
    "@hono/node-server": "^1.13.7",
    "@types/connect": "^3.4.38",
    "@types/jsdom": "^27.0.0",
    "@types/pg": "^8.16.0",
    "@types/ssh2": "^1.15.5",
    "bun-plugin-solid": "^1.0.0",
    "hono": "^4.6.14",
    "hono-alibaba-cloud-fc3-adapter": "^1.0.2",
    "monaco-editor": "^0.55.1",
    "node-forge": "^1.3.3",
    "pg": "^8.16.3",
    "pg-cursor": "^2.15.3",
    "pgsql-ast-parser": "^12.0.2",
    "solid-js": "^1.9.5",
    "sql-formatter": "^15.7.2",
    "ssh2": "^1.17.0",
    "tsx": "^4.21.0",
    "vite-plus": "^0.1.12",
    "xlsx": "^0.18.5"
  },
  "packageManager": "pnpm@10.32.1"
}